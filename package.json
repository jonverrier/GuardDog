{
  "name": "@jonverrier/guard-dog",
  "version": "0.1.0",
  "description": "CLI tool that reviews a codebase for evolutionary architecture risks",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonverrier/GuardDog.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "bin": {
    "guarddog": "dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc && npm run copy-assets",
    "copy-assets": "copyfiles -u 1 src/Prompts.json dist/",
    "prepublishOnly": "npm run build",
    "test": "jest --selectProjects unit",
    "test:ci": "jest --selectProjects ci",
    "cover": "jest --selectProjects ci --coverage --coverageReporters=html text lcov",
    "generate-docs": "c4-auto --dir ./src --files \"*.ts\" \"*.tsx\" --one-month --c4component --c4context --rollup"
  },
  "dependencies": {
    "@jonverrier/prompt-repository": "^0.3.23",
    "minimatch": "^10.0.1",
    "tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@jonverrier/c4-auto": "^0.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.10",
    "@types/sinon": "^17.0.3",
    "copyfiles": "^2.4.1",
    "expect": "^29.7.0",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "sinon": "^19.0.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
}
